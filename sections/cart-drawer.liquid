{%- if settings.cart_drawer_enabled -%}
  <aside class="cart-drawer" data-cart-drawer aria-hidden="true">
    <button class="cart-drawer__overlay" type="button" data-cart-close aria-label="{{ 'general.close' | t }}"></button>
    <div class="cart-drawer__panel" role="dialog" aria-modal="true" aria-label="{{ 'cart.general.title' | t }}">
      <div class="cart-drawer__header">
        <button class="icon-button" type="button" data-cart-close aria-label="{{ 'general.close' | t }}">
          {% render 'icon', icon: 'close' %}
        </button>
        <h2>{{ 'cart.general.title' | t }}</h2>
        {%- if settings.free_shipping_text != blank -%}
          <p>{{ settings.free_shipping_text }}</p>
        {%- endif -%}
      </div>
      <div class="cart-drawer__items">
        {%- if cart.item_count == 0 -%}
          <p class="empty-state">{{ 'cart.general.empty' | t }}</p>
        {%- else -%}
          {%- for item in cart.items -%}
            <div class="cart-item">
              {%- if item.image -%}
                {{ item.image | image_url: width: 160 | image_tag: loading: 'lazy' }}
              {%- endif -%}
              <div>
                <h3>{{ item.product.title }}</h3>
                <p>{{ item.variant.title }}</p>
                <p>Qty {{ item.quantity }}</p>
                <a href="{{ item.url_to_remove }}">{{ 'cart.general.remove' | t }}</a>
              </div>
              <div class="cart-item__price">{{ item.final_line_price | money }}</div>
            </div>
          {%- endfor -%}
        {%- endif -%}
      </div>
      <div class="cart-drawer__footer">
        <p><strong>{{ 'cart.general.subtotal' | t }}</strong> {{ cart.total_price | money }}</p>
        <a class="button button--full" href="{{ routes.cart_url }}">{{ 'cart.general.checkout' | t }}</a>
      </div>
    </div>
  </aside>
{%- endif -%}

{% schema %}
{
  "name": "Cart drawer",
  "settings": []
}
{% endschema %}
