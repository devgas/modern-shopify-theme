{%- if section.settings.text != blank -%}
  <div class="announcement">
    <div class="announcement__inner page-width">
      <span>{{ section.settings.text }}</span>
    </div>
  </div>
{%- endif -%}

{% schema %}
{
  "name": "Announcement bar",
  "settings": [
    {
      "type": "text",
      "id": "text",
      "label": "Text",
      "default": "New season arrivals are here"
    }
  ]
}
{% endschema %}
