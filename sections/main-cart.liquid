<section class="section">
  <div class="page-width">
    <h1 class="page-title">{{ 'cart.general.title' | t }}</h1>
    {%- if cart.item_count == 0 -%}
      <p class="empty-state">{{ 'cart.general.empty' | t }}</p>
    {%- else -%}
      <form action="{{ routes.cart_url }}" method="post">
        {%- for item in cart.items -%}
          <div class="cart-item">
            {%- if item.image -%}
              {{ item.image | image_url: width: 200 | image_tag: loading: 'lazy' }}
            {%- endif -%}
            <div>
              <h3>{{ item.product.title }}</h3>
              <p>{{ item.variant.title }}</p>
              <input class="quantity-input" type="number" name="updates[]" value="{{ item.quantity }}" min="0">
              <a href="{{ item.url_to_remove }}">{{ 'cart.general.remove' | t }}</a>
            </div>
            <div class="cart-item__price">{{ item.final_line_price | money }}</div>
          </div>
        {%- endfor -%}
        <div class="cart-drawer__footer">
          <p><strong>{{ 'cart.general.subtotal' | t }}</strong> {{ cart.total_price | money }}</p>
          <button class="button button--secondary" type="submit" name="update">Update</button>
          <button class="button" type="submit" name="checkout">{{ 'cart.general.checkout' | t }}</button>
        </div>
      </form>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Main cart",
  "settings": []
}
{% endschema %}
