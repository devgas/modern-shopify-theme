<section class="section">
  <div class="page-width">
    <div class="section-heading">
      <div>
        <p class="eyebrow">{{ section.settings.eyebrow }}</p>
        <h2>{{ section.settings.heading }}</h2>
      </div>
    </div>
    <div class="collection-grid">
      {%- for block in section.blocks -%}
        {%- assign collection = collections[block.settings.collection] -%}
        <a class="collection-card" href="{{ collection.url | default: routes.collections_url }}" {{ block.shopify_attributes }}>
          {%- if collection.featured_image -%}
            {{ collection.featured_image | image_url: width: 1000 | image_tag: loading: 'lazy' }}
          {%- elsif block.settings.image != blank -%}
            {{ block.settings.image | image_url: width: 1000 | image_tag: loading: 'lazy' }}
          {%- else -%}
            {%- case forloop.index -%}
              {%- when 1 -%}
                {%- assign fallback_image = 'product-knit-sweater.png' -%}
              {%- when 2 -%}
                {%- assign fallback_image = 'product-amber-bottle.png' -%}
              {%- when 3 -%}
                {%- assign fallback_image = 'product-ceramic-mug.png' -%}
              {%- else -%}
                {%- assign fallback_image = 'product-leather-notebook.png' -%}
            {%- endcase -%}
            <img src="{{ fallback_image | asset_url }}" alt="{{ collection.title | default: block.settings.heading | escape }}" width="1254" height="1254" loading="lazy">
          {%- endif -%}
          <div class="collection-card__content">
            <h3>{{ collection.title | default: block.settings.heading }}</h3>
            <span>Shop now {% render 'icon', icon: 'arrow' %}</span>
          </div>
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Collection list",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Shop by edit" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Curated categories" }
  ],
  "blocks": [
    {
      "type": "collection",
      "name": "Collection",
      "settings": [
        { "type": "collection", "id": "collection", "label": "Collection" },
        { "type": "image_picker", "id": "image", "label": "Fallback image" },
        { "type": "text", "id": "heading", "label": "Fallback heading", "default": "Collection" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Collection list",
      "blocks": [{ "type": "collection" }, { "type": "collection" }, { "type": "collection" }]
    }
  ]
}
{% endschema %}
