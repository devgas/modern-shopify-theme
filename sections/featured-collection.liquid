{%- assign collection = collections[section.settings.collection] -%}
<section class="section">
  <div class="page-width">
    <div class="section-heading">
      <div>
        <p class="eyebrow">{{ section.settings.eyebrow }}</p>
        <h2>{{ section.settings.heading }}</h2>
        {%- if section.settings.text != blank -%}
          <p>{{ section.settings.text }}</p>
        {%- endif -%}
      </div>
      {%- if collection != blank -%}
        <a class="button button--secondary" href="{{ collection.url }}">{{ 'sections.featured_collection.view_all' | t }}</a>
      {%- endif -%}
    </div>

    <div class="product-grid">
      {%- if collection != blank -%}
        {%- for product in collection.products limit: section.settings.limit -%}
          {% render 'product-card', product: product %}
        {%- endfor -%}
      {%- else -%}
        {%- for i in (1..4) -%}
          <article class="product-card">
            <div class="product-card__media">{{ 'product-' | append: i | placeholder_svg_tag }}</div>
            <div class="product-card__body">
              <span class="product-card__title">Product title</span>
              <span class="price">$48.00</span>
            </div>
          </article>
        {%- endfor -%}
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Featured collection",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Selected products" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Best sellers" },
    { "type": "textarea", "id": "text", "label": "Text", "default": "Highlight the products that define the store." },
    { "type": "collection", "id": "collection", "label": "Collection" },
    { "type": "range", "id": "limit", "min": 2, "max": 12, "step": 1, "label": "Products", "default": 4 }
  ],
  "presets": [{ "name": "Featured collection" }]
}
{% endschema %}
