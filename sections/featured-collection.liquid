{%- assign collection = collections[section.settings.collection] -%}
<section class="section">
  <div class="page-width">
    <div class="section-heading">
      <div>
        <p class="eyebrow">{{ section.settings.eyebrow }}</p>
        <h2>{{ section.settings.heading }}</h2>
        {%- if section.settings.text != blank -%}
          <p>{{ section.settings.text }}</p>
        {%- endif -%}
      </div>
      {%- if collection != blank -%}
        <a class="button button--secondary" href="{{ collection.url }}">{{ 'sections.featured_collection.view_all' | t }}</a>
      {%- endif -%}
    </div>

    <div class="product-grid">
      {%- if collection != blank -%}
        {%- for product in collection.products limit: section.settings.limit -%}
          {% render 'product-card', product: product %}
        {%- endfor -%}
      {%- else -%}
        {%- assign demo_images = 'product-knit-sweater.png,product-amber-bottle.png,product-ceramic-mug.png,product-leather-notebook.png' | split: ',' -%}
        {%- assign demo_titles = 'Ribbed knit sweater,Amber hand wash,Ceramic coffee mug,Leather notebook' | split: ',' -%}
        {%- assign demo_prices = '$128.00,$34.00,$28.00,$74.00' | split: ',' -%}
        {%- for image in demo_images -%}
          {%- assign index = forloop.index0 -%}
          <article class="product-card">
            <div class="product-card__media">
              {{ image | asset_url | image_tag: loading: 'lazy' }}
            </div>
            <div class="product-card__body">
              <span class="product-card__title">{{ demo_titles[index] }}</span>
              <span class="price">{{ demo_prices[index] }}</span>
            </div>
          </article>
        {%- endfor -%}
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Featured collection",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Selected products" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Best sellers" },
    { "type": "textarea", "id": "text", "label": "Text", "default": "Highlight the products that define the store." },
    { "type": "collection", "id": "collection", "label": "Collection" },
    { "type": "range", "id": "limit", "min": 2, "max": 12, "step": 1, "label": "Products", "default": 4 }
  ],
  "presets": [{ "name": "Featured collection" }]
}
{% endschema %}
