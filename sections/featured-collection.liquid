{%- assign collection = collections[section.settings.collection] -%}
<section class="section">
  <div class="page-width">
    <div class="section-heading">
      <div>
        <p class="eyebrow">{{ section.settings.eyebrow }}</p>
        <h2>{{ section.settings.heading }}</h2>
        {%- if section.settings.text != blank -%}
          <p>{{ section.settings.text }}</p>
        {%- endif -%}
      </div>
      {%- if collection != blank -%}
        <a class="button button--secondary" href="{{ collection.url }}">{{ 'sections.featured_collection.view_all' | t }}</a>
      {%- endif -%}
    </div>

    <div class="product-grid">
      {%- if collection != blank -%}
        {%- for product in collection.products limit: section.settings.limit -%}
          {% render 'product-card', product: product %}
        {%- endfor -%}
      {%- else -%}
        {%- assign demo_url = routes.all_products_collection_url | default: routes.collections_url -%}
        {%- assign demo_images = 'product-knit-sweater.png,product-amber-bottle.png,product-ceramic-mug.png,product-leather-notebook.png' | split: ',' -%}
        {%- for image in demo_images -%}
          {%- case forloop.index -%}
            {%- when 1 -%}
              {%- assign demo_title = 'Ribbed knit sweater' -%}
              {%- assign demo_price = '$128.00' -%}
            {%- when 2 -%}
              {%- assign demo_title = 'Amber hand wash' -%}
              {%- assign demo_price = '$34.00' -%}
            {%- when 3 -%}
              {%- assign demo_title = 'Ceramic coffee mug' -%}
              {%- assign demo_price = '$28.00' -%}
            {%- else -%}
              {%- assign demo_title = 'Leather notebook' -%}
              {%- assign demo_price = '$74.00' -%}
          {%- endcase -%}
          <article class="product-card">
            <div class="product-card__media">
              <a href="{{ demo_url }}" aria-label="{{ demo_title | escape }}">
                <img src="{{ image | asset_url }}" alt="{{ demo_title | escape }}" width="1254" height="1254" loading="lazy">
              </a>
            </div>
            <div class="product-card__body">
              <a class="product-card__title" href="{{ demo_url }}">{{ demo_title }}</a>
              <span class="price">{{ demo_price }}</span>
            </div>
          </article>
        {%- endfor -%}
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Featured collection",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Selected products" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Best sellers" },
    { "type": "textarea", "id": "text", "label": "Text", "default": "Highlight the products that define the store." },
    { "type": "collection", "id": "collection", "label": "Collection" },
    { "type": "range", "id": "limit", "min": 2, "max": 12, "step": 1, "label": "Products", "default": 4 }
  ],
  "presets": [{ "name": "Featured collection" }]
}
{% endschema %}
