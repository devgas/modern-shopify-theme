<section class="hero">
  <div class="hero__media">
    {%- if section.settings.image != blank -%}
      {{ section.settings.image | image_url: width: 2400 | image_tag: loading: 'eager', sizes: '100vw', widths: '900, 1400, 1800, 2400' }}
    {%- else -%}
      <img src="{{ 'hero-lifestyle-banner.png' | asset_url }}" alt="" width="1774" height="887" loading="eager">
    {%- endif -%}
  </div>
  <div class="hero__content page-width">
    <div class="hero__copy">
      {%- if section.settings.eyebrow != blank -%}
        <p class="eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}
      <h1>{{ section.settings.heading }}</h1>
      {%- if section.settings.text != blank -%}
        <p class="hero__text">{{ section.settings.text }}</p>
      {%- endif -%}
      {%- assign primary_link = section.settings.button_link | default: routes.all_products_collection_url -%}
      {%- assign secondary_link = section.settings.secondary_link | default: routes.collections_url -%}
      <div class="hero__actions">
        {%- if section.settings.button_label != blank -%}
          <a class="button" href="{{ primary_link }}">{{ section.settings.button_label }} {% render 'icon', icon: 'arrow' %}</a>
        {%- endif -%}
        {%- if section.settings.secondary_label != blank -%}
          <a class="button button--secondary" href="{{ secondary_link }}">{{ section.settings.secondary_label }}</a>
        {%- endif -%}
      </div>
    </div>

    <div class="hero__commerce" aria-label="{{ section.settings.commerce_aria_label | escape }}">
      <div class="hero__commerce-image">
        {%- if section.settings.commerce_image != blank -%}
          {{ section.settings.commerce_image | image_url: width: 600 | image_tag: loading: 'eager', sizes: '112px', widths: '224, 400, 600' }}
        {%- else -%}
          <img src="{{ 'product-ceramic-mug.png' | asset_url }}" alt="" width="1254" height="1254" loading="eager">
        {%- endif -%}
      </div>
      <div class="hero__commerce-copy">
        {%- if section.settings.commerce_eyebrow != blank -%}
          <p>{{ section.settings.commerce_eyebrow }}</p>
        {%- endif -%}
        {%- if section.settings.commerce_heading != blank -%}
          <h2>{{ section.settings.commerce_heading }}</h2>
        {%- endif -%}
        {%- if section.settings.commerce_link_label != blank -%}
          <a href="{{ section.settings.commerce_link | default: primary_link }}">
            {{ section.settings.commerce_link_label }} {% render 'icon', icon: 'arrow' %}
          </a>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Image" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "New collection" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Modern essentials" },
    { "type": "textarea", "id": "text", "label": "Text", "default": "A clean, fast Shopify theme built around editorial product storytelling and high-converting merchandising." },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Shop arrivals" },
    { "type": "url", "id": "button_link", "label": "Button link" },
    { "type": "text", "id": "secondary_label", "label": "Secondary label", "default": "Explore collections" },
    { "type": "url", "id": "secondary_link", "label": "Secondary link" },
    { "type": "header", "content": "Commerce highlight" },
    { "type": "text", "id": "commerce_aria_label", "label": "Accessibility label", "default": "Store highlights" },
    { "type": "image_picker", "id": "commerce_image", "label": "Image" },
    { "type": "text", "id": "commerce_eyebrow", "label": "Eyebrow", "default": "Popular now" },
    { "type": "text", "id": "commerce_heading", "label": "Heading", "default": "Everyday pieces, ready to ship." },
    { "type": "text", "id": "commerce_link_label", "label": "Link label", "default": "Shop the edit" },
    { "type": "url", "id": "commerce_link", "label": "Link" }
  ],
  "presets": [{ "name": "Hero" }]
}
{% endschema %}
