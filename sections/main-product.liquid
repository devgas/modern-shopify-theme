<section class="product page-width">
  <div class="product-media">
    {%- for media in product.media -%}
      <div class="product-media__item">
        {{ media | image_url: width: 1200 | image_tag: loading: 'lazy', sizes: '(min-width: 990px) 34vw, 100vw', widths: '500, 800, 1200' }}
      </div>
    {%- else -%}
      <div class="product-media__item">{{ 'product-1' | placeholder_svg_tag }}</div>
    {%- endfor -%}
  </div>

  <div class="product-info">
    <p class="eyebrow">{{ product.vendor }}</p>
    <h1>{{ product.title }}</h1>
    <div class="product-info__price">{% render 'price', product: product %}</div>

    {%- form 'product', product, class: 'product-form', data-product-form: '' -%}
      {%- unless product.has_only_default_variant -%}
        <div class="product-options">
          {%- for option in product.options_with_values -%}
            <div>
              <label for="Option-{{ section.id }}-{{ forloop.index0 }}">{{ option.name }}</label>
              <select id="Option-{{ section.id }}-{{ forloop.index0 }}" data-option-select>
                {%- for value in option.values -%}
                  <option value="{{ value | escape }}" {% if option.selected_value == value %}selected{% endif %}>
                    {{ value }}
                  </option>
                {%- endfor -%}
              </select>
            </div>
          {%- endfor -%}
        </div>

        <input data-variant-input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
        <script type="application/json" data-product-variants>
          [
            {%- for variant in product.variants -%}
              {
                "id": {{ variant.id | json }},
                "available": {{ variant.available | json }},
                "options": {{ variant.options | json }}
              }{%- unless forloop.last -%},{%- endunless -%}
            {%- endfor -%}
          ]
        </script>
      {%- else -%}
        <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
      {%- endunless -%}

      <div>
        <label for="Quantity">{{ 'products.product.quantity' | t }}</label>
        <input class="quantity-input" id="Quantity" type="number" name="quantity" value="1" min="1">
      </div>

      <button
        class="button button--full"
        type="submit"
        data-product-submit
        data-add-label="{{ 'products.product.add_to_cart' | t | escape }}"
        data-sold-out-label="{{ 'products.product.sold_out' | t | escape }}"
        data-unavailable-label="{{ 'products.product.unavailable' | t | escape }}"
        {% unless product.selected_or_first_available_variant.available %}disabled{% endunless %}
      >
        {%- if product.selected_or_first_available_variant.available -%}
          {{ 'products.product.add_to_cart' | t }}
        {%- else -%}
          {{ 'products.product.sold_out' | t }}
        {%- endif -%}
      </button>
      {{ form | payment_button }}
    {%- endform -%}

    {%- if product.description != blank -%}
      <div class="rte">
        <h2>{{ 'products.product.description' | t }}</h2>
        {{ product.description }}
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Main product",
  "settings": []
}
{% endschema %}
