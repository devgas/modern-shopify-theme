<section class="section">
  <div class="page-width">
    <h1 class="page-title">{{ 'general.search' | t }}</h1>
    <form action="{{ routes.search_url }}" method="get" role="search" class="field">
      <input type="search" name="q" value="{{ search.terms | escape }}" placeholder="{{ 'general.search' | t }}">
      <button class="button" type="submit">{{ 'general.search' | t }}</button>
    </form>

    {%- if search.performed -%}
      <div class="section-heading">
        <p>{{ 'search.general.results_with_count' | t: count: search.results_count, terms: search.terms }}</p>
      </div>
      <div class="product-grid">
        {%- for item in search.results -%}
          {%- if item.object_type == 'product' -%}
            {% render 'product-card', product: item %}
          {%- endif -%}
        {%- else -%}
          <p class="empty-state">{{ 'search.general.empty' | t }}</p>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Main search",
  "settings": []
}
{% endschema %}
